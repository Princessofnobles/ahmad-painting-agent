# ============================================================
# Ahmad Al Zahidi Painting LLC — AI Agent Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- SerpAPI (Google Maps / Search scraping) ---
SERPAPI_KEY=your_serpapi_key_here

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM_NAME=Ahmad Al Zahidi Painting LLC

# --- WhatsApp (Twilio or WA Business API) ---
WHATSAPP_PROVIDER=twilio          # twilio | wabiz
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=whatsapp:+971xxxxxxxx

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/ahmad_painting.db
# Production: postgresql+asyncpg://user:pass@host/dbname

# --- App ---
APP_SECRET_KEY=change_this_to_random_string_64_chars
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# --- Company Info ---
COMPANY_NAME=Ahmad Al Zahidi Painting LLC
COMPANY_PHONE=+971 XX XXX XXXX
COMPANY_EMAIL=info@ahmadpainting.ae
COMPANY_WEBSITE=https://ahmadpainting.ae
COMPANY_LOCATION=Dubai, UAE

# --- Agent Schedule ---
LEAD_DISCOVERY_CRON=0 8 * * *        # 8am daily
FOLLOWUP_CRON=0 9 * * *              # 9am daily
SEO_SCAN_CRON=0 10 * * 1             # Monday 10am
